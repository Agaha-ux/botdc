@bot.tree.command(name="clear", description="Limpa o chat")
@app_commands.checks.has_permissions(administrator=True)
async def clear(interaction: discord.Interaction, quantidade: int = 100):
    await interaction.response.defer(ephemeral=True)
    await interaction.channel.purge(limit=quantidade)
    await interaction.followup.send(f"🧹 {quantidade} mensagens limpas!", ephemeral=True)

@bot.tree.command(name="chat", description="Replica mensagem por ID")
@app_commands.checks.has_permissions(administrator=True)
async def chat_cmd(interaction: discord.Interaction, id_mensagem: str, canal: Optional[discord.TextChannel] = None):
    await interaction.response.defer(ephemeral=True)
    destino = canal or interaction.channel
    try:
        msg_id = int(id_mensagem)
        for channel in interaction.guild.text_channels:
            try:
                msg = await channel.fetch_message(msg_id)
                await destino.send(content=msg.content, embeds=msg.embeds)
                return await interaction.followup.send("✅ Mensagem replicada!", ephemeral=True)
            except: continue
        await interaction.followup.send("❌ Mensagem não encontrada.", ephemeral=True)
    except: await interaction.followup.send("❌ ID Inválido.", ephemeral=True)


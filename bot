class EmbedModal(Modal, title="🎨 Criar Anúncio"):
    titulo = TextInput(label="Título", required=True)
    descricao = TextInput(label="Descrição", style=discord.TextStyle.paragraph, required=True)
    cor_hex = TextInput(label="Cor Hex", default="#3498db", min_length=7, max_length=7)
    imagem = TextInput(label="Link da Imagem (Opcional)", required=False)

    async def on_submit(self, interaction: discord.Interaction):
        try: cor = discord.Color(int(self.cor_hex.value.lstrip('#'), 16))
        except: cor = discord.Color.blue()
        embed = discord.Embed(title=self.titulo.value, description=self.descricao.value, color=cor)
        if self.imagem.value: embed.set_image(url=self.imagem.value)
        await interaction.channel.send(embed=embed)
        await interaction.response.send_message("✅ Enviado!", ephemeral=True)


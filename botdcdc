        super().__init__(timeout=None)

    @discord.ui.button(
        label="Registrar no SMP",
        style=discord.ButtonStyle.green,
        custom_id="btn_registrar_smp",
        emoji="✅"
    )
    async def registrar_smp(self, interaction: discord.Interaction, button: discord.ui.Button):
        cargo = interaction.guild.get_role(ID_CARGO_SMP)

        if not cargo:
            return await interaction.response.send_message(
                "❌ Cargo do SMP não encontrado. Verifique o ID configurado.",
                ephemeral=True
            )

        if cargo in interaction.user.roles:
            return await interaction.response.send_message(
                "⚠️ Você já está registrado no SMP!",
                ephemeral=True
            )

        await interaction.user.add_roles(cargo)

        await interaction.response.send_message(
            f"✅ Registro concluído! Você recebeu o cargo {cargo.mention} e agora pode ver os canais do SMP.",
            ephemeral=True
        )



class DenunciaModal(Modal, title="🚨 Formulário de Denúncia"):
    denunciado = TextInput(
        label="Quem você está denunciando?",
        placeholder="Nome ou ID",
        required=True
    )

    motivo = TextInput(
        label="Motivo",
        style=discord.TextStyle.paragraph,
        required=True,
        min_length=10
    )

    provas = TextInput(
        label="Provas (Links)",
        placeholder="Links de imagens/vídeos",
        required=True
    )

    async def on_submit(self, interaction: discord.Interaction):
        num = get_next_ticket_number()
        protocolo = str(num).zfill(4)

        categoria = interaction.guild.get_channel(ID_CATEGORIA_DENUNCIA)
        cargo_suporte = interaction.guild.get_role(ID_CARGO_SUPORTE)

        overwrites = {
            interaction.guild.default_role: discord.PermissionOverwrite(read_messages=False),
            interaction.user: discord.PermissionOverwrite(read_messages=True, send_messages=True)
        }

        if cargo_suporte:
            overwrites[cargo_suporte] = discord.PermissionOverwrite(read_messages=True, send_messages=True)

        canal = await interaction.guild.create_text_channel(
            name=f"denúncia-{protocolo}",
            category=categoria,
            overwrites=overwrites,
            topic=f"ID: {interaction.user.id}"
        )

        embed = discord.Embed(
            title=f"🚨 Denúncia #{protocolo}",
            color=discord.Color.red()
        )

        embed.add_field(name="Autor:", value=interaction.user.mention, inline=True)
        embed.add_field(name="Denunciado:", value=self.denunciado.value, inline=True)
        embed.add_field(name="Motivo:", value=self.motivo.value, inline=False)
        embed.add_field(name="Provas:", value=self.provas.value, inline=False)

        await canal.send(
            content=f"🔔 <@&{ID_CARGO_SUPORTE}>",
            embed=embed,
            view=CloseTicketView(interaction.user.id)
        )

        await interaction.response.send_message(
            f"✅ Denúncia enviada: {canal.mention}",
            ephemeral=True
        )


